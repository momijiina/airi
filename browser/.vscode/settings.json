{
  "chat.tools.terminal.autoApprove": {
    "/^# PowerShellでSystem\\.Drawingを使ってアイコンを生成\nAdd-Type -AssemblyName System\\.Drawing\n\nfunction New-Icon \\{\n    param\\(\\[int\\]\\$Size, \\[string\\]\\$Path\\)\n    \n    \\$bmp = New-Object System\\.Drawing\\.Bitmap\\(\\$Size, \\$Size\\)\n    \\$g = \\[System\\.Drawing\\.Graphics\\]::FromImage\\(\\$bmp\\)\n    \\$g\\.SmoothingMode = \\[System\\.Drawing\\.Drawing2D\\.SmoothingMode\\]::AntiAlias\n    \\$g\\.InterpolationMode = \\[System\\.Drawing\\.Drawing2D\\.InterpolationMode\\]::HighQualityBicubic\n    \n    # 背景グラデーション\n    \\$rect = New-Object System\\.Drawing\\.Rectangle\\(0, 0, \\$Size, \\$Size\\)\n    \\$brush = New-Object System\\.Drawing\\.Drawing2D\\.LinearGradientBrush\\(\\$rect, \\[System\\.Drawing\\.Color\\]::FromArgb\\(26, 115, 232\\), \\[System\\.Drawing\\.Color\\]::FromArgb\\(124, 77, 255\\), \\[System\\.Drawing\\.Drawing2D\\.LinearGradientMode\\]::ForwardDiagonal\\)\n    \n    # 角丸四角\n    \\$r = \\[int\\]\\(\\$Size \\* 0\\.18\\)\n    \\$path = New-Object System\\.Drawing\\.Drawing2D\\.GraphicsPath\n    \\$path\\.AddArc\\(0, 0, \\$r\\*2, \\$r\\*2, 180, 90\\)\n    \\$path\\.AddArc\\(\\$Size - \\$r\\*2, 0, \\$r\\*2, \\$r\\*2, 270, 90\\)\n    \\$path\\.AddArc\\(\\$Size - \\$r\\*2, \\$Size - \\$r\\*2, \\$r\\*2, \\$r\\*2, 0, 90\\)\n    \\$path\\.AddArc\\(0, \\$Size - \\$r\\*2, \\$r\\*2, \\$r\\*2, 90, 90\\)\n    \\$path\\.CloseFigure\\(\\)\n    \\$g\\.FillPath\\(\\$brush, \\$path\\)\n    \n    # ロボット顔 - 白い四角\n    \\$headW = \\[int\\]\\(\\$Size \\* 0\\.5\\)\n    \\$headH = \\[int\\]\\(\\$Size \\* 0\\.32\\)\n    \\$headX = \\[int\\]\\(\\(\\$Size - \\$headW\\) / 2\\)\n    \\$headY = \\[int\\]\\(\\$Size \\* 0\\.28\\)\n    \\$whiteBrush = New-Object System\\.Drawing\\.SolidBrush\\(\\[System\\.Drawing\\.Color\\]::White\\)\n    \\$headR = \\[int\\]\\(\\$Size \\* 0\\.06\\)\n    \\$headPath = New-Object System\\.Drawing\\.Drawing2D\\.GraphicsPath\n    \\$headPath\\.AddArc\\(\\$headX, \\$headY, \\$headR\\*2, \\$headR\\*2, 180, 90\\)\n    \\$headPath\\.AddArc\\(\\$headX \\+ \\$headW - \\$headR\\*2, \\$headY, \\$headR\\*2, \\$headR\\*2, 270, 90\\)\n    \\$headPath\\.AddArc\\(\\$headX \\+ \\$headW - \\$headR\\*2, \\$headY \\+ \\$headH - \\$headR\\*2, \\$headR\\*2, \\$headR\\*2, 0, 90\\)\n    \\$headPath\\.AddArc\\(\\$headX, \\$headY \\+ \\$headH - \\$headR\\*2, \\$headR\\*2, \\$headR\\*2, 90, 90\\)\n    \\$headPath\\.CloseFigure\\(\\)\n    \\$g\\.FillPath\\(\\$whiteBrush, \\$headPath\\)\n    \n    # 目\n    \\$blueBrush = New-Object System\\.Drawing\\.SolidBrush\\(\\[System\\.Drawing\\.Color\\]::FromArgb\\(26, 115, 232\\)\\)\n    \\$eyeR = \\[Math\\]::Max\\(1, \\[int\\]\\(\\$Size \\* 0\\.06\\)\\)\n    \\$eyeY = \\[int\\]\\(\\$headY \\+ \\$headH / 2 - \\$eyeR\\)\n    \\$g\\.FillEllipse\\(\\$blueBrush, \\[int\\]\\(\\$Size/2 - \\$Size\\*0\\.12\\), \\$eyeY, \\$eyeR\\*2, \\$eyeR\\*2\\)\n    \\$g\\.FillEllipse\\(\\$blueBrush, \\[int\\]\\(\\$Size/2 \\+ \\$Size\\*0\\.05\\), \\$eyeY, \\$eyeR\\*2, \\$eyeR\\*2\\)\n    \n    # アンテナ\n    \\$pen = New-Object System\\.Drawing\\.Pen\\(\\[System\\.Drawing\\.Color\\]::White, \\[Math\\]::Max\\(1, \\[int\\]\\(\\$Size \\* 0\\.04\\)\\)\\)\n    \\$pen\\.StartCap = \\[System\\.Drawing\\.Drawing2D\\.LineCap\\]::Round\n    \\$pen\\.EndCap = \\[System\\.Drawing\\.Drawing2D\\.LineCap\\]::Round\n    \\$antX = \\[int\\]\\(\\$Size / 2\\)\n    \\$g\\.DrawLine\\(\\$pen, \\$antX, \\$headY, \\$antX, \\[int\\]\\(\\$headY - \\$Size \\* 0\\.1\\)\\)\n    \\$antR = \\[Math\\]::Max\\(1, \\[int\\]\\(\\$Size \\* 0\\.04\\)\\)\n    \\$g\\.FillEllipse\\(\\$whiteBrush, \\$antX - \\$antR, \\[int\\]\\(\\$headY - \\$Size\\*0\\.1 - \\$antR\\), \\$antR\\*2, \\$antR\\*2\\)\n    \n    # AIテキスト\n    if \\(\\$Size -ge 48\\) \\{\n        \\$fontSize = \\[Math\\]::Max\\(8, \\[int\\]\\(\\$Size \\* 0\\.18\\)\\)\n        \\$font = New-Object System\\.Drawing\\.Font\\(\"Segoe UI\", \\$fontSize, \\[System\\.Drawing\\.FontStyle\\]::Bold\\)\n        \\$sf = New-Object System\\.Drawing\\.StringFormat\n        \\$sf\\.Alignment = \\[System\\.Drawing\\.StringAlignment\\]::Center\n        \\$sf\\.LineAlignment = \\[System\\.Drawing\\.StringAlignment\\]::Center\n        \\$textRect = New-Object System\\.Drawing\\.RectangleF\\(0, \\[float\\]\\(\\$Size \\* 0\\.62\\), \\$Size, \\[float\\]\\(\\$Size \\* 0\\.35\\)\\)\n        \\$g\\.DrawString\\(\"AI\", \\$font, \\$whiteBrush, \\$textRect, \\$sf\\)\n    \\}\n    \n    \\$g\\.Dispose\\(\\)\n    \\$bmp\\.Save\\(\\$Path, \\[System\\.Drawing\\.Imaging\\.ImageFormat\\]::Png\\)\n    \\$bmp\\.Dispose\\(\\)\n    Write-Host \"Generated: \\$Path \\(\\$Size x \\$Size\\)\"\n\\}\n\n\\$iconsDir = \"c:\\\\Users\\\\admin\\\\Desktop\\\\llm browser\\\\icons\"\nNew-Icon -Size 16 -Path \"\\$iconsDir\\\\icon16\\.png\"\nNew-Icon -Size 48 -Path \"\\$iconsDir\\\\icon48\\.png\"\nNew-Icon -Size 128 -Path \"\\$iconsDir\\\\icon128\\.png\"\n$/": {
      "approve": true,
      "matchCommandLine": true
    }
  }
}
